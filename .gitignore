# .gitignore for syspilot

# ======================================
# Dogfooding: syspilot uses itself
# .syspilot/ is created by setup agent
# ======================================
.syspilot/
.jarvis/
.vscode/
managers/
projects/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Sphinx build output
docs/_build/

# Local config that shouldn't be shared
.env
*.local

# temporary files
temp/

